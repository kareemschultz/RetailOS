# shadcn/studio Pro
# Infisical: /credentials/shadcnstudio/ → SHADCN_STUDIO_EMAIL, SHADCN_STUDIO_LICENSE_KEY
# Map to EMAIL and LICENSE_KEY for the shadcn CLI
EMAIL=
LICENSE_KEY=

# Magic UI Pro
# Infisical: /credentials/magicui/ → MAGICUI_PRO_TOKEN
MAGICUI_PRO_REGISTRY_TOKEN=

# Local docker-compose services (placeholders only; override in real environments — §9/§25/§36)
POSTGRES_PASSWORD=password
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# App consumption vars (REDIS_URL, S3_*) live in apps/server/.env.example
