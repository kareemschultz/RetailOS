{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core", "ultracite/biome/react"],
  "files": {
    // Vendored agent skills/hooks and generated files are not RetailOS source — don't lint them.
    // Impeccable installs a copy per harness (.claude/.agents/.cursor/.github); exclude all of them.
    "includes": [
      "!**/.agents/skills",
      "!**/skills/impeccable",
      "!**/.codex/hooks.json",
      "!**/.cursor/hooks.json",
      "!**/.github/hooks/impeccable.json",
      "!**/routeTree.gen.ts",
      "!**/*.gen.ts",
      "!**/.source",
      "!**/apps/fumadocs",
      // Static public assets (favicon, robots) are served verbatim — not JSX/source to lint.
      "!**/apps/web/public",
      // Agent worktrees are full repo copies (each with its own biome root) — never lint them.
      "!**/.claude/worktrees"
    ]
  },
  "linter": {
    "rules": {
      // These ultracite defaults conflict with framework/monorepo conventions we deliberately use:
      "performance": {
        // Package entry points (packages/*/src/index.ts) are intentional barrels; Drizzle uses `import * as schema`.
        "noBarrelFile": "off",
        "noNamespaceImport": "off"
      },
      "style": {
        // TanStack Start / Expo Router file-based routing requires names like `$.tsx`, `__root.tsx`, `(drawer)`, `api.chat.ts`.
        "useFilenamingConvention": "off"
      }
    }
  },
  "overrides": [
    {
      // Vendored AdminCN feature scaffolds (dense data tables, recharts charts,
      // sample-data widgets) — copied verbatim from the template, themed to our
      // tokens, kept as-is until wired to real data. Their strict-lint patterns
      // (array-index keys on static sample rows, recharts SVG shapes without a
      // <title>, non-null assertions / nested ternaries / accumulator spreads in
      // the copied table code) are relaxed here; tighten as each is wired up.
      "includes": [
        "apps/web/src/features/**",
        "packages/ui/src/components/avatar.tsx",
        "packages/ui/src/components/background-ripple.tsx",
        "packages/ui/src/components/chart.tsx",
        "packages/ui/src/components/circular-progress.tsx",
        "packages/ui/src/components/field.tsx",
        "packages/ui/src/components/input-group.tsx",
        "packages/ui/src/components/pagination.tsx",
        "packages/ui/src/components/progress.tsx",
        "packages/ui/src/components/rating.tsx",
        "packages/ui/src/components/scroll-area.tsx",
        "packages/ui/src/components/switch.tsx",
        "packages/ui/src/components/textarea.tsx",
        "packages/ui/src/components/timeline.tsx",
        "packages/ui/src/components/toggle.tsx",
        "packages/ui/src/components/toggle-group.tsx"
      ],
      "linter": {
        "rules": {
          "a11y": {
            "noAmbiguousAnchorText": "off",
            "noNoninteractiveElementInteractions": "off",
            "noRedundantAlt": "off",
            "noStaticElementInteractions": "off",
            "noSvgWithoutTitle": "off",
            "useAnchorContent": "off",
            "useAriaPropsSupportedByRole": "off",
            "useKeyWithClickEvents": "off",
            "useSemanticElements": "off",
            "useValidAnchor": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off",
            "noForEach": "off",
            "useOptionalChain": "off"
          },
          "correctness": { "useImageSize": "off" },
          "performance": { "noAccumulatingSpread": "off" },
          "style": {
            "noNestedTernary": "off",
            "noNonNullAssertion": "off",
            "useConsistentTypeDefinitions": "off"
          },
          "suspicious": {
            "noAlert": "off",
            "noArrayIndexKey": "off",
            "noExplicitAny": "off",
            "useIterableCallbackReturn": "off"
          }
        }
      }
    }
  ]
}
