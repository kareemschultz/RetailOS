BETTER_AUTH_SECRET=<generate with: openssl rand -base64 32>
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3001

DATABASE_URL=postgresql://postgres:password@localhost:5432/RetailOS

# Redis (caching, rate limiting, sync/queues/jobs — charter §4/§47). Endpoint is env-driven (§9/§36).
REDIS_URL=redis://localhost:6379

# Object storage — S3-compatible (MinIO locally; self-hostable per data residency, §9/§36).
# Placeholders only — real credentials come from the environment, never committed (§25).
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=retailos
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
