BETTER_AUTH_SECRET=<generate with: openssl rand -base64 32>
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3001

# Runtime connects as retailos_app — NOBYPASSRLS/NOSUPERUSER, subject to RLS (ADR 0006).
DATABASE_URL=postgresql://retailos_app:retailos_app@localhost:5432/RetailOS
# Migrations connect as retailos_migrator (acts as retailos_owner). Used by drizzle-kit only.
MIGRATION_DATABASE_URL=postgresql://retailos_migrator:retailos_migrator@localhost:5432/RetailOS
# Bootstrap roles first (as superuser), BEFORE migrations — see packages/db/src/bootstrap/roles.sql:
#   docker exec -i RetailOS-postgres psql -U postgres -d RetailOS < packages/db/src/bootstrap/roles.sql
# Dev/CI passwords above are NOT secrets; real deployments inject role secrets from the secrets manager (§25).

# Redis (caching, rate limiting, sync/queues/jobs — charter §4/§47). Endpoint is env-driven (§9/§36).
REDIS_URL=redis://localhost:6379

# Object storage — S3-compatible (MinIO locally; self-hostable per data residency, §9/§36).
# Placeholders only — real credentials come from the environment, never committed (§25).
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=retailos
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
