{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "base-lyra",
  "rsc": false,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "src/styles/globals.css",
    "baseColor": "neutral",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "aliases": {
    "components": "@RetailOS/ui/components",
    "utils": "@RetailOS/ui/lib/utils",
    "hooks": "@RetailOS/ui/hooks",
    "lib": "@RetailOS/ui/lib",
    "ui": "@RetailOS/ui/components"
  },
  "menuColor": "default",
  "menuAccent": "subtle",
  "registries": {
    "@magicui": "https://magicui.design/r/{name}.json",
    "@magicui-pro": {
      "url": "https://pro.magicui.design/registry/{name}",
      "headers": {
        "Authorization": "Bearer ${MAGICUI_PRO_REGISTRY_TOKEN}"
      }
    },
    "@shadcn-studio": "https://shadcnstudio.com/r/{name}.json",
    "@ss-components": {
      "url": "https://shadcnstudio.com/r/components/{name}.json",
      "params": {
        "email": "${EMAIL}",
        "license_key": "${LICENSE_KEY}"
      }
    },
    "@ss-blocks": {
      "url": "https://shadcnstudio.com/r/blocks/{name}.json",
      "params": {
        "email": "${EMAIL}",
        "license_key": "${LICENSE_KEY}"
      }
    },
    "@ss-themes": {
      "url": "https://shadcnstudio.com/r/themes/{name}.json",
      "params": {
        "email": "${EMAIL}",
        "license_key": "${LICENSE_KEY}"
      }
    },
    "@reui": "https://reui.io/r/base-nova/{name}.json"
  }
}
