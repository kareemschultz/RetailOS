{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "base-lyra",
  "rsc": false,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "src/styles/globals.css",
    "baseColor": "neutral",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "aliases": {
    "components": "@RetailOS/ui/components",
    "utils": "@RetailOS/ui/lib/utils",
    "hooks": "@RetailOS/ui/hooks",
    "lib": "@RetailOS/ui/lib",
    "ui": "@RetailOS/ui/components"
  },
  "menuColor": "default",
  "menuAccent": "subtle",
  "registries": {
    "@magicui": {
      "url": "https://r.magicui.design/{name}.json",
      "headers": {
        "Authorization": "Bearer ${MAGICUI_PRO_REGISTRY_TOKEN}"
      }
    },
    "@ss-blocks": {
      "url": "https://shadcnstudio.com/registry/{name}.json"
    }
  }
}
